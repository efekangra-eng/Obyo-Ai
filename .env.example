# GEMINI_API_KEY: Standard single API key required for Gemini AI API calls.
# You can use a single GEMINI_API_KEY for all model requests (recommended).
# Alternatively, if you want separate keys, you can specify GEMINI_API_KEY_PRIMARY and GEMINI_API_KEY_SECONDARY.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_API_KEY_PRIMARY="MY_GEMINI_API_KEY"
GEMINI_API_KEY_SECONDARY="MY_GEMINI_API_KEY"

# Separate Dedicated Keys for Each Technical Analysis AI Model (Optional)
# If provided, each specialized AI model runs on its own dedicated client/key.
GEMINI_API_KEY_TREND="MY_GEMINI_API_KEY"
GEMINI_API_KEY_MOMENTUM="MY_GEMINI_API_KEY"
GEMINI_API_KEY_VOLUME="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
